<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Gold accent strip -->
    <View
        android:id="@+id/accent_strip"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/antique_gold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Compact header — single row, smaller padding -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/accent_strip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score Title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/aged_ivory"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_composer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:textColor="@color/antique_gold_dim"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_score"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="💾"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_fingering"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="1-2-3"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="⬆ Export"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

        </LinearLayout>

    </LinearLayout>

    <!-- Score canvas (scrollable) — takes maximum vertical space -->
    <ScrollView
        android:id="@+id/scroll_score"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@color/background"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_edit_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.cellomusic.app.ui.viewer.view.ScoreCanvasView
            android:id="@+id/score_canvas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background"
            android:minHeight="300dp" />

    </ScrollView>

    <!-- Edit toolbar (shown when a note is selected) -->
    <HorizontalScrollView
        android:id="@+id/layout_edit_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:paddingVertical="4dp"
        android:elevation="6dp"
        android:visibility="gone"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_controls">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pitch_up"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="▲ Pitch"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pitch_down"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="▼ Pitch"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dur_shorter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="◂ Dur"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dur_longer"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Dur ▸"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clef"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="𝄢 Clef"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_note"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="✕ Del"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Compact playback controls — single-row layout for landscape -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="8dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Seekbar + Play/Stop buttons in one line -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="■"
                android:textSize="14sp"
                android:textColor="@color/aged_ivory"
                android:minWidth="40dp"
                android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▶ Play"
                android:textSize="13sp"
                android:textColor="@color/oak_deep"
                android:textStyle="bold"
                android:minWidth="80dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="4dp"
                app:backgroundTint="@color/antique_gold"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⏸"
                android:textSize="14sp"
                android:textColor="@color/aged_ivory"
                android:minWidth="40dp"
                android:paddingHorizontal="8dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <SeekBar
                android:id="@+id/seekbar_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/antique_gold"
                android:thumbTint="@color/antique_gold" />

            <TextView
                android:id="@+id/tv_measure_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M1"
                android:textSize="11sp"
                android:fontFamily="serif"
                android:textColor="@color/antique_gold_dim"
                android:paddingStart="6dp" />

        </LinearLayout>

        <!-- Row 2: Speed + Volume + Transpose all in one compact row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spd:"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_tempo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="20"
                android:valueTo="200"
                android:value="120"
                android:stepSize="1"
                app:thumbColor="@color/antique_gold"
                app:trackColorActive="@color/antique_gold"
                app:trackColorInactive="@color/antique_gold_dim" />

            <TextView
                android:id="@+id/tv_tempo_value"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:text="120 BPM"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="end" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="@color/antique_gold_dim"
                android:layout_marginHorizontal="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol:"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                android:value="1.0"
                android:stepSize="0.05"
                app:thumbColor="@color/antique_gold"
                app:trackColorActive="@color/antique_gold"
                app:trackColorInactive="@color/antique_gold_dim" />

            <TextView
                android:id="@+id/tv_volume_value"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="end" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="@color/antique_gold_dim"
                android:layout_marginHorizontal="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_transpose_down"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="−"
                android:textSize="16sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                android:minWidth="0dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <TextView
                android:id="@+id/tv_transpose_value"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="0 st"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory"
                android:fontFamily="serif"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_transpose_up"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                android:minWidth="0dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

        </LinearLayout>

        <!-- Row 3: Practice Mode — Loop + Count-in + Tempo Ramp (compact) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loop_toggle"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Loop"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loop_start"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="A:"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:paddingHorizontal="6dp"
                android:visibility="gone"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loop_end"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="B:"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:paddingHorizontal="6dp"
                android:visibility="gone"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <TextView
                android:id="@+id/tv_loop_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="@color/antique_gold_dim"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_count_in"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Count-in"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tempo_ramp"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Tempo+"
                android:textSize="10sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <TextView
                android:id="@+id/tv_ramp_step"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+5%/pass"
                android:textSize="10sp"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:visibility="gone"
                android:layout_marginEnd="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ramp_less"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="−"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                android:minWidth="0dp"
                android:visibility="gone"
                android:layout_marginEnd="1dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ramp_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="+"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                android:minWidth="0dp"
                android:visibility="gone"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
