<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <View
            android:id="@+id/banner_top"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  BOW COACH  ✦"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/antique_gold"
            android:fontFamily="serif"
            android:paddingTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/banner_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time bowing technique feedback via microphone"
            android:textSize="12sp"
            android:textColor="@color/aged_ivory_dim"
            android:fontFamily="serif"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="12dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Bow pressure gauge panel -->
        <LinearLayout
            android:id="@+id/panel_pressure"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOW PRESSURE"
                android:textSize="11sp"
                android:letterSpacing="0.14"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"/>

            <com.cellomusic.app.ui.bow.view.BowPressureView
                android:id="@+id/bow_pressure_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- Pressure label (dynamic text) -->
        <TextView
            android:id="@+id/tv_pressure_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Start to begin"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/aged_ivory"
            android:fontFamily="serif"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/panel_pressure"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Three stat cards -->
        <LinearLayout
            android:id="@+id/panel_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tv_pressure_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Tone Quality -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_oak_panel"
                android:layout_marginEnd="6dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/tv_tone_quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/antique_gold"
                    android:fontFamily="serif"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tone Quality"
                    android:textSize="10sp"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Volume -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_oak_panel"
                android:layout_marginHorizontal="3dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/tv_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/antique_gold"
                    android:fontFamily="serif"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volume"
                    android:textSize="10sp"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Bow Changes -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_oak_panel"
                android:layout_marginStart="6dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/tv_bow_changes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/antique_gold"
                    android:fontFamily="serif"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bow Changes"
                    android:textSize="10sp"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Tip text -->
        <TextView
            android:id="@+id/tv_tip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/aged_ivory_dim"
            android:fontFamily="serif"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/panel_stats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Avg quality (shown during session) -->
        <TextView
            android:id="@+id/tv_avg_quality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_tip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Start / Stop button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_stop"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="▶  Start"
            android:textColor="@color/oak_deep"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="24dp"
            app:backgroundTint="@color/antique_gold"
            app:cornerRadius="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_avg_quality"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginTop="28dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toBottomOf="@id/btn_start_stop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
