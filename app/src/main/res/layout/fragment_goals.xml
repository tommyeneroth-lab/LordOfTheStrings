<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Goals"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_empty_goals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No goals yet. Tap + to create your first practice goal!"
                android:textSize="14sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_active_goals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="40dp"
                android:layout_marginVertical="12dp"
                android:background="@color/antique_gold_dim" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completed"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_completed_goals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_goal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:backgroundTint="@color/antique_gold"
        android:contentDescription="Add Goal"
        app:tint="@color/oak_deep"
        app:srcCompat="@android:drawable/ic_input_add"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
