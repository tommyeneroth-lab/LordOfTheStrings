<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oak_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Gold top bar -->
        <View
            android:id="@+id/banner_top"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  METRONOME  ✦"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/antique_gold"
            android:fontFamily="serif"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/banner_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/divider_title"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="8dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Beat indicator in raised panel -->
        <LinearLayout
            android:id="@+id/panel_beat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.cellomusic.app.ui.metronome.view.BeatIndicatorView
                android:id="@+id/beat_indicator"
                android:layout_width="match_parent"
                android:layout_height="260dp" />

        </LinearLayout>

        <!-- BPM value -->
        <TextView
            android:id="@+id/tv_bpm_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="120"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="@color/aged_ivory"
            android:fontFamily="serif"
            app:layout_constraintTop_toBottomOf="@id/panel_beat"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/tv_bpm_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM"
            android:textSize="12sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            app:layout_constraintTop_toBottomOf="@id/tv_bpm_value"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BPM slider controls -->
        <LinearLayout
            android:id="@+id/layout_bpm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_bpm_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bpm_down"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="22sp"
                android:textColor="@color/aged_ivory"
                app:cornerRadius="24dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_bpm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:valueFrom="20"
                android:valueTo="300"
                android:value="120"
                android:stepSize="1"
                app:trackColor="@color/oak_grain"
                app:thumbColor="@color/antique_gold"
                app:tickColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bpm_up"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="22sp"
                android:textColor="@color/aged_ivory"
                app:cornerRadius="24dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <View
            android:id="@+id/divider_mid"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="16dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/layout_bpm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Time signature -->
        <LinearLayout
            android:id="@+id/layout_timesig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/divider_mid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time Signature"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:paddingEnd="12dp" />

            <Spinner
                android:id="@+id/spinner_beats"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/antique_gold_dim"
                android:popupBackground="@color/oak_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/aged_ivory"
                android:fontFamily="serif" />

            <Spinner
                android:id="@+id/spinner_denominator"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/antique_gold_dim"
                android:popupBackground="@color/oak_dark" />

        </LinearLayout>

        <!-- Tap tempo + Play buttons -->
        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_timesig"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tap_tempo"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Tap Tempo"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_stop"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Start"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/oak_deep"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/antique_gold"
                app:cornerRadius="6dp" />

        </LinearLayout>

        <!-- Bottom gold rule -->
        <View
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toBottomOf="@id/layout_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
