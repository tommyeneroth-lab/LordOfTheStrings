<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Gold top bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/antique_gold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✦  SCALE TRAINER  ✦"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/antique_gold"
            android:fontFamily="serif"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="8dp"
            android:background="@color/antique_gold_dim" />

        <!-- Scale picker: category spinner + scale spinner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:paddingEnd="10dp" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/antique_gold_dim"
                android:popupBackground="@color/background" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scale"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:paddingEnd="10dp" />

            <Spinner
                android:id="@+id/spinner_scale"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/antique_gold_dim"
                android:popupBackground="@color/background" />

        </LinearLayout>

        <!-- Selected scale details card -->
        <LinearLayout
            android:id="@+id/panel_scale_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/tv_scale_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_scale_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="center"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/tv_scale_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="center"
                android:fontFeatureSettings="italic"
                android:paddingTop="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/antique_gold_dim"
                android:layout_marginVertical="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORE"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif"
                android:paddingBottom="6dp" />

            <!--
              Engraved scale notation.  Height is fixed rather than
              wrap-content because ScoreCanvasView paints into its
              available canvas; the number of systems (staff rows) varies
              with the scale length, and 260dp comfortably holds 2–3
              systems for a 3-octave scale.
            -->
            <com.cellomusic.app.ui.viewer.view.ScoreCanvasView
                android:id="@+id/score_canvas"
                android:layout_width="match_parent"
                android:layout_height="260dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_listen"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔊  Listen"
                android:textColor="@color/antique_gold"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="10dp"
                app:strokeColor="@color/antique_gold_dim"
                app:cornerRadius="6dp"
                app:backgroundTint="@color/oak_dark"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Metronome + timer row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_oak_panel"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tv_bpm_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="80"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/aged_ivory"
                    android:fontFamily="serif"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BPM"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif"
                    android:gravity="center" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_oak_panel"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/aged_ivory"
                    android:fontFamily="serif"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DRILL TIME"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- BPM slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bpm_down"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="−"
                android:textSize="22sp"
                android:textColor="@color/aged_ivory"
                app:cornerRadius="22dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_bpm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:valueFrom="20"
                android:valueTo="300"
                android:value="80"
                android:stepSize="1"
                app:trackColor="@color/oak_grain"
                app:thumbColor="@color/antique_gold"
                app:tickColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bpm_up"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textSize="22sp"
                android:textColor="@color/aged_ivory"
                app:cornerRadius="22dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Beat indicator dots -->
        <LinearLayout
            android:id="@+id/beat_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <View
                android:id="@+id/dot_1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_oak_panel" />
            <View
                android:id="@+id/dot_2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_oak_panel" />
            <View
                android:id="@+id/dot_3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_oak_panel" />
            <View
                android:id="@+id/dot_4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_oak_panel" />

        </LinearLayout>

        <!-- Start / Reset buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_margin="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="Reset"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="6dp"
                app:strokeColor="@color/antique_gold_dim"
                app:backgroundTint="@color/oak_panel"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_stop"
                android:layout_width="0dp"
                android:layout_weight="1.3"
                android:layout_height="56dp"
                android:text="Start"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/oak_deep"
                android:layout_marginHorizontal="6dp"
                app:backgroundTint="@color/antique_gold"
                app:cornerRadius="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="Log"
                android:textColor="@color/aged_ivory"
                android:layout_marginStart="6dp"
                app:strokeColor="@color/antique_gold"
                app:backgroundTint="@color/oak_dark"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Catalog hint -->
        <TextView
            android:id="@+id/tv_catalog_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/antique_gold"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
