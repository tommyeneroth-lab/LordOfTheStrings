<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Gold accent strip -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/antique_gold" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:tabTextColor="@color/aged_ivory_dim"
            app:tabSelectedTextColor="@color/antique_gold"
            app:tabIndicatorColor="@color/antique_gold"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabGravity="fill" />

        <!-- Subtle divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22C9A84C" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Fireworks overlay (above everything) -->
    <com.cellomusic.app.ui.journal.view.FireworksOverlayView
        android:id="@+id/fireworks_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="100dp"
        android:visibility="gone" />

</FrameLayout>
