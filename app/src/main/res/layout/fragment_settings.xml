<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <View
            android:id="@+id/banner_top"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  SETTINGS  ✦"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/antique_gold"
            android:fontFamily="serif"
            android:paddingTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/banner_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="10dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- OMR Server section -->
        <LinearLayout
            android:id="@+id/panel_server"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OMR SERVER"
                android:textSize="11sp"
                android:letterSpacing="0.14"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Server URL for high-quality music score recognition.\nLeave empty to use the built-in on-device OMR."
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif" />

            <android.widget.EditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="https://xxxx.trycloudflare.com"
                android:textColor="@color/aged_ivory"
                android:textColorHint="@color/aged_ivory_dim"
                android:background="@drawable/bg_oak_panel"
                android:padding="10dp"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:inputType="textUri"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_url"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Save"
                    android:textColor="@color/oak_deep"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="@color/antique_gold"
                    app:cornerRadius="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_test_server"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Test Connection"
                    android:textColor="@color/aged_ivory"
                    app:strokeColor="@color/antique_gold_dim"
                    app:backgroundTint="@color/oak_panel"
                    app:cornerRadius="6dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_test_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Status indicator -->
        <LinearLayout
            android:id="@+id/panel_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/panel_server"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_status_dot"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:text="●"
                android:textSize="14sp"
                android:textColor="@color/aged_ivory_dim"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_status_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No server configured — using on-device OMR"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- Practice Reminders section -->
        <LinearLayout
            android:id="@+id/panel_reminder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/panel_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRACTICE REMINDERS"
                android:textSize="11sp"
                android:letterSpacing="0.14"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Get a daily notification to remind you to practice."
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_reminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily reminder"
                    android:textColor="@color/aged_ivory"
                    android:textSize="14sp"
                    android:fontFamily="serif"
                    app:thumbTint="@color/antique_gold"
                    app:trackTint="@color/antique_gold_dim" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pick_time"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="18:00"
                    android:textSize="14sp"
                    android:textColor="@color/aged_ivory"
                    android:fontFamily="monospace"
                    app:strokeColor="@color/antique_gold_dim"
                    style="@style/Widget.LOTS.Button" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_reminder_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Info box -->
        <LinearLayout
            android:id="@+id/panel_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/panel_reminder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW TO SET UP YOUR OMR SERVER"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="1. Run install_omr_server.sh on your Mac Mini\n2. Run ~/omr-server/start_tunnel.sh\n3. Copy the https://xxxx.trycloudflare.com URL here\n4. Tap Test Connection to verify\n\nWhen a server URL is set, PDF imports use the server\n(Oemer engine) for much higher accuracy. JPEG, MIDI\nand MP3 imports always use the on-device engine."
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginTop="24dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toBottomOf="@id/panel_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
