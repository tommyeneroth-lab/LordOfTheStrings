<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Gold accent strip -->
    <View
        android:id="@+id/accent_strip"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/antique_gold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Score title bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/accent_strip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score Title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/aged_ivory" />

                <TextView
                    android:id="@+id/tv_composer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:fontFamily="serif"
                    android:textColor="@color/antique_gold_dim" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💾"
                android:textSize="16sp"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_fingering"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1-2-3"
                android:textSize="13sp"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬆ Export"
                android:textSize="13sp"
                style="@style/Widget.LOTS.Button"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim" />

        </LinearLayout>

    </LinearLayout>

    <!-- Score canvas (scrollable) -->
    <ScrollView
        android:id="@+id/scroll_score"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        android:background="@color/background"
        app:layout_constraintBottom_toTopOf="@id/layout_edit_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.cellomusic.app.ui.viewer.view.ScoreCanvasView
            android:id="@+id/score_canvas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background"
            android:minHeight="600dp" />

    </ScrollView>

    <!-- Edit toolbar (shown when a note is selected) -->
    <HorizontalScrollView
        android:id="@+id/layout_edit_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:paddingVertical="6dp"
        android:elevation="6dp"
        android:visibility="gone"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_controls">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pitch_up"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▲ Pitch"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pitch_down"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▼ Pitch"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dur_shorter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="◂ Dur"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dur_longer"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Dur ▸"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clef"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="𝄢 Clef"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="4dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_note"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✕ Del"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Playback controls -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="8dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Progress seekbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekbar_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/antique_gold"
                android:thumbTint="@color/antique_gold" />

            <TextView
                android:id="@+id/tv_measure_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Measure 1"
                android:textSize="12sp"
                android:fontFamily="serif"
                android:textColor="@color/antique_gold_dim"
                android:paddingStart="8dp" />

        </LinearLayout>

        <!-- Playback buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="■ Stop"
                android:textColor="@color/aged_ivory"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="▶ Play"
                android:textColor="@color/oak_deep"
                android:textStyle="bold"
                android:layout_marginHorizontal="8dp"
                app:backgroundTint="@color/antique_gold"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Tempo control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed:"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingEnd="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_tempo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.25"
                android:valueTo="2.0"
                android:value="1.0"
                android:stepSize="0.05"
                app:thumbColor="@color/antique_gold"
                app:trackColorActive="@color/antique_gold"
                app:trackColorInactive="@color/antique_gold_dim" />

            <TextView
                android:id="@+id/tv_tempo_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="end" />

        </LinearLayout>

        <!-- Volume control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Volume:"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingEnd="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                android:value="1.0"
                android:stepSize="0.05"
                app:thumbColor="@color/antique_gold"
                app:trackColorActive="@color/antique_gold"
                app:trackColorInactive="@color/antique_gold_dim" />

            <TextView
                android:id="@+id/tv_volume_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:gravity="end" />

        </LinearLayout>

        <!-- Transpose control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transpose:"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_transpose_down"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

            <TextView
                android:id="@+id/tv_transpose_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0 st"
                android:textSize="13sp"
                android:textColor="@color/aged_ivory"
                android:fontFamily="serif"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_transpose_up"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:textColor="@color/aged_ivory"
                android:padding="0dp"
                app:strokeColor="@color/antique_gold_dim"
                style="@style/Widget.LOTS.Button" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
