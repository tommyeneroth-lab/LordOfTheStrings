<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/score_background">

    <!-- Score title bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tv_composer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/white_70" />

    </LinearLayout>

    <!-- Score canvas (scrollable) -->
    <ScrollView
        android:id="@+id/scroll_score"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.cellomusic.app.ui.viewer.view.ScoreCanvasView
            android:id="@+id/score_canvas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="600dp" />

    </ScrollView>

    <!-- Playback controls -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="8dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Progress seekbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekbar_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_measure_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Measure 1"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:paddingStart="8dp" />

        </LinearLayout>

        <!-- Playback buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="■ Stop"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="▶ Play"
                android:layout_marginHorizontal="8dp" />

        </LinearLayout>

        <!-- Tempo control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed:"
                android:textSize="13sp"
                android:paddingEnd="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_tempo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.25"
                android:valueTo="2.0"
                android:value="1.0"
                android:stepSize="0.05" />

            <TextView
                android:id="@+id/tv_tempo_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="13sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Volume control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Volume:"
                android:textSize="13sp"
                android:paddingEnd="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                android:value="1.0"
                android:stepSize="0.05" />

            <TextView
                android:id="@+id/tv_volume_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="13sp"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
