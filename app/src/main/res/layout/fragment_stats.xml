<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Streak Badge (prominent) -->
        <com.cellomusic.app.ui.journal.view.StreakBadgeView
            android:id="@+id/streak_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" />

        <!-- Level + XP Progress -->
        <com.cellomusic.app.ui.journal.view.LevelProgressView
            android:id="@+id/level_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Daily XP goal ring (auto-targeted from 7-day rolling average). -->
        <com.cellomusic.app.ui.journal.view.DailyGoalRingView
            android:id="@+id/daily_goal_ring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="@color/antique_gold_dim" />

        <!-- ═══ Weekly / Monthly Summary Cards ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS WEEK"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:id="@+id/card_weekly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/summary_card_bg"
            android:padding="14dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_weekly_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_weekly_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingTop="2dp" />

            <TextView
                android:id="@+id/tv_weekly_compare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="serif"
                android:paddingTop="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS MONTH"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:paddingBottom="6dp"
            android:paddingTop="8dp" />

        <LinearLayout
            android:id="@+id/card_monthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/summary_card_bg"
            android:padding="14dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_monthly_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_monthly_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingTop="2dp" />

            <TextView
                android:id="@+id/tv_monthly_compare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="serif"
                android:paddingTop="4dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="@color/antique_gold_dim" />

        <!-- ═══ Category Breakdown ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY BREAKDOWN"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:paddingBottom="10dp" />

        <com.cellomusic.app.ui.journal.view.CategoryBreakdownView
            android:id="@+id/category_breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="@color/antique_gold_dim" />

        <!-- ═══ Calendar Heatmap ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRACTICE CALENDAR"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif"
            android:paddingBottom="8dp" />

        <com.cellomusic.app.ui.journal.view.CalendarHeatmapView
            android:id="@+id/calendar_heatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Day detail popup (hidden by default) -->
        <LinearLayout
            android:id="@+id/day_detail_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/summary_card_bg"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_day_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_day_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/aged_ivory_dim"
                android:fontFamily="serif"
                android:paddingTop="4dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="@color/antique_gold_dim" />

        <!-- ═══ Achievements ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACHIEVEMENTS"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/antique_gold_dim"
                android:fontFamily="serif" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_achievements_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif" />
        </LinearLayout>

        <com.cellomusic.app.ui.journal.view.AchievementGridView
            android:id="@+id/achievement_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="@color/antique_gold_dim" />

        <!-- ═══ Tempo Graph ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEMPO PROGRESSION"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="@color/antique_gold_dim"
            android:fontFamily="serif" />

        <Spinner
            android:id="@+id/spinner_tempo_piece"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="@color/antique_gold_dim"
            android:popupBackground="@color/background" />

        <com.cellomusic.app.ui.journal.view.TempoGraphView
            android:id="@+id/tempo_graph"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
