<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <View
            android:id="@+id/banner_top"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  DECIBEL METER  ✦"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/antique_gold"
            android:fontFamily="serif"
            android:paddingTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/banner_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor your practice volume to protect your hearing"
            android:textSize="12sp"
            android:textColor="@color/aged_ivory_dim"
            android:fontFamily="serif"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="12dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Main dB display panel -->
        <LinearLayout
            android:id="@+id/panel_db"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_oak_panel"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_db_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— dB"
                android:textSize="64sp"
                android:textStyle="bold"
                android:textColor="@color/aged_ivory"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tv_db_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start measuring"
                android:textSize="14sp"
                android:textColor="@color/antique_gold"
                android:fontFamily="serif"
                android:layout_marginTop="4dp" />

            <!-- VU meter bar -->
            <com.cellomusic.app.ui.decibel.DecibelBarView
                android:id="@+id/decibel_bar"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- Peak + Average readings -->
        <LinearLayout
            android:id="@+id/layout_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/panel_db"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_oak_panel"
                android:padding="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PEAK"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tv_peak_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— dB"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/aged_ivory"
                    android:fontFamily="serif" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_oak_panel"
                android:padding="12dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVERAGE"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:textColor="@color/antique_gold_dim"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tv_avg_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— dB"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/aged_ivory"
                    android:fontFamily="serif" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="16dp"
            android:background="@color/antique_gold_dim"
            app:layout_constraintTop_toBottomOf="@id/layout_stats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Hearing safety guide -->
        <TextView
            android:id="@+id/tv_guide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="14dp"
            android:text="Safe levels:  &lt;70 dB comfortable  •  70–85 dB caution  •  &gt;85 dB risk"
            android:textSize="11sp"
            android:textColor="@color/aged_ivory_dim"
            android:fontFamily="serif"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Start/Stop button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_stop"
            android:layout_width="180dp"
            android:layout_height="52dp"
            android:text="Start Meter"
            android:textColor="@color/oak_deep"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="20dp"
            app:backgroundTint="@color/antique_gold"
            app:cornerRadius="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_guide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_peak"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:text="Reset Peak"
            android:textSize="12sp"
            android:textColor="@color/aged_ivory"
            android:layout_marginTop="8dp"
            app:strokeColor="@color/antique_gold_dim"
            app:backgroundTint="@color/oak_panel"
            app:cornerRadius="6dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/btn_start_stop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginTop="24dp"
            android:background="@color/antique_gold"
            app:layout_constraintTop_toBottomOf="@id/btn_reset_peak"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
