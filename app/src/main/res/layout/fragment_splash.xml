<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-bleed splash image -->
    <ImageView
        android:id="@+id/iv_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/splash_bg_jpg"
        android:scaleType="centerCrop"
        android:contentDescription="Lord of the Strings" />

    <!-- Random cellist quote — top 20% of screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="#1A000000">

        <TextView
            android:id="@+id/tv_quote_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textColor="#FFF4E4C1"
            android:textSize="12sp"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:lineSpacingExtra="0.3dp" />

        <TextView
            android:id="@+id/tv_quote_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textColor="#FFC9A84C"
            android:textSize="11sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:paddingTop="8dp" />
    </LinearLayout>

    <!-- Tap-anywhere overlay -->
    <View
        android:id="@+id/touch_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
