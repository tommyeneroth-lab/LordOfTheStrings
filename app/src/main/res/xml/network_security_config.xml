<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP to local network IPs (home server) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.86.33</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <!-- All other traffic (Cloudflare tunnel etc.) must use HTTPS -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
