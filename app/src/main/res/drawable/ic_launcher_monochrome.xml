<?xml version="1.0" encoding="utf-8"?>
<!--
  Themed-icon (monochrome) layer for Android 13+. The system strips colour
  and re-tints this silhouette to match the user's wallpaper theme, so
  every path must use a single opaque fill.

  Safe zone: the inner 66×66dp of the 108×108 viewport. Everything outside
  may be clipped by whatever mask the launcher applies (circle, squircle…).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scroll / pegbox at top. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M50,30 L58,30 L58,22 C58,20 55.5,18 54,18 C52.5,18 50,20 50,22 Z" />

    <!-- Cello body — figure-eight silhouette with upper and lower bouts. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M54,30 C46,30 40,35 40,42 C40,47 43,51 47,53 C43,55 40,59 40,64 C40,72 46,78 54,78 C62,78 68,72 68,64 C68,59 65,55 61,53 C65,51 68,47 68,42 C68,35 62,30 54,30 Z" />

    <!-- Strings: 4 thin vertical bars across the body. Drawn as filled
         rectangles (not stroked paths) so the system's tinting hits
         every pixel uniformly. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M49.8,30 h0.8 v48 h-0.8 z M52.6,30 h0.8 v48 h-0.8 z M54.6,30 h0.8 v48 h-0.8 z M57.4,30 h0.8 v48 h-0.8 z" />

    <!-- Endpin at bottom. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M53.25,78 h1.5 v8 h-1.5 z" />

</vector>
