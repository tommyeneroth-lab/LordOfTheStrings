<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.cellomusic.app.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash"
        xmlns:tools="http://schemas.android.com/tools">

        <action
            android:id="@+id/action_splash_to_library"
            app:destination="@id/libraryFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/libraryFragment"
        android:name="com.cellomusic.app.ui.library.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library"
        xmlns:tools="http://schemas.android.com/tools">

        <action
            android:id="@+id/action_library_to_viewer"
            app:destination="@id/scoreViewerFragment" />

        <action
            android:id="@+id/action_library_to_import"
            app:destination="@id/importFragment" />

        <action
            android:id="@+id/action_library_to_settings"
            app:destination="@id/settingsFragment" />

    </fragment>

    <fragment
        android:id="@+id/tunerFragment"
        android:name="com.cellomusic.app.ui.tuner.TunerFragment"
        android:label="Tuner"
        tools:layout="@layout/fragment_tuner"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/metronomeFragment"
        android:name="com.cellomusic.app.ui.metronome.MetronomeFragment"
        android:label="Metronome"
        tools:layout="@layout/fragment_metronome"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/droneFragment"
        android:name="com.cellomusic.app.ui.drone.DroneFragment"
        android:label="Drone"
        tools:layout="@layout/fragment_drone"
        xmlns:tools="http://schemas.android.com/tools">

        <action
            android:id="@+id/action_drone_to_decibel"
            app:destination="@id/decibelMeterFragment" />

    </fragment>

    <fragment
        android:id="@+id/practiceJournalFragment"
        android:name="com.cellomusic.app.ui.journal.JournalHostFragment"
        android:label="Journal"
        tools:layout="@layout/fragment_journal_host"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/decibelMeterFragment"
        android:name="com.cellomusic.app.ui.decibel.DecibelMeterFragment"
        android:label="dB Meter"
        tools:layout="@layout/fragment_decibel_meter"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/scoreViewerFragment"
        android:name="com.cellomusic.app.ui.viewer.ScoreViewerFragment"
        android:label="Score"
        tools:layout="@layout/fragment_score_viewer"
        xmlns:tools="http://schemas.android.com/tools">

        <argument
            android:name="scoreId"
            app:argType="long"
            android:defaultValue="-1L" />

    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.cellomusic.app.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/importFragment"
        android:name="com.cellomusic.app.ui.import_.ImportFragment"
        android:label="Import Score"
        xmlns:tools="http://schemas.android.com/tools"
        tools:layout="@layout/fragment_library" />

</navigation>
